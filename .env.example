# Copy this file to ".env" and fill in your Supabase project values.
# Find them in: Supabase dashboard -> Project Settings -> API
#
# Leave these BLANK to run the app fully offline / local-only.
# Sync to the cloud only turns on once both values are present.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# All app tables live in this dedicated Postgres schema (not "public").
# Must be added to Supabase -> Settings -> API -> Exposed schemas.
VITE_SUPABASE_SCHEMA=machinery-piecerate

# Name of the Supabase Storage bucket that holds work photos.
VITE_SUPABASE_PHOTO_BUCKET=photos
